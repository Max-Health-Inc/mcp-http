{
  "name": "@maxhealth.tech/mcp-http",
  "version": "0.1.6",
  "type": "module",
  "description": "Framework-agnostic MCP HTTP transport with RFC 9728 OAuth plumbing for edge runtimes",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./hono": {
      "types": "./dist/hono/index.d.ts",
      "import": "./dist/hono/index.js"
    },
    "./cloudflare": {
      "types": "./dist/cloudflare/index.d.ts",
      "import": "./dist/cloudflare/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run check",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-threshold 0.9 --coverage-include-source-map",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun test --coverage && bun run build && node -e \"require('fs').existsSync('dist/src/index.js') || process.exit(1)\""
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.29.0",
    "hono": ">=4.12.0"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    }
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/bun": "^1.3.0",
    "eslint": "^10.3.0",
    "hono": "^4.12.0",
    "prettier": "^3.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Max-Health-Inc/mcp-http"
  },
  "publishConfig": {
    "access": "public"
  }
}
